<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ site_title }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      background: #0f1923;
      color: #e8eaf0;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
    }
    .card {
      background: #1a2535;
      border: 1px solid #2d3f5a;
      border-radius: 12px;
      padding: 3rem 4rem;
      max-width: 640px;
      text-align: center;
      box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    }
    .badge {
      display: inline-block;
      background: #1e6ff1;
      color: #fff;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.25rem 0.75rem;
      border-radius: 999px;
      margin-bottom: 1.5rem;
    }
    h1 { font-size: 2rem; font-weight: 700; margin-bottom: 1rem; }
    p  { color: #9aaccc; line-height: 1.6; margin-bottom: 0.5rem; }
    .meta { margin-top: 2rem; font-size: 0.8rem; color: #4a6080; }
  </style>
</head>
<body>
  <div class="card">
    <span class="badge">{{ environment }}</span>
    <h1>{{ site_heading }}</h1>
    <p>{{ site_body }}</p>
    <p class="meta">Project: {{ project }} &nbsp;|&nbsp; Powered by nginx on Amazon Linux 2023</p>
  </div>
</body>
</html>
